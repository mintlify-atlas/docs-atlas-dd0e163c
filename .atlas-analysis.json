  "keyFeatures": [
    "Autonomous ML experimentation using Gemini 3 Flash",
    "Thought Signatures for reasoning continuity across API calls",
    "Hypothesis-driven experiment design with confidence scoring",
    "Automatic code generation using Jinja2 templates",
    "MLflow integration for experiment tracking and artifacts",
    "Natural language constraints for experiment guidance",
    "Publication-ready narrative reports with insights",
    "Support for regression and classification tasks",
    "Rich CLI with colored console output",
    "Resume capability for interrupted experiments"
